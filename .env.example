# Database Configuration
POSTGRES_DB=userdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URLs for different frameworks
DATABASE_URL=postgresql://admin:change_this_password@postgres:5432/userdb
DOTNET_DATABASE_URL=Host=postgres;Database=userdb;Username=admin;Password=change_this_password

# Backend Ports
FASTAPI_PORT=8001
DJANGO_PORT=8002
NODE_PORT=8003
DOTNET_PORT=8004
FRONTEND_PORT=8080
NGINX_PORT=80

# Docker Image Names
FASTAPI_IMAGE=multiframework-login-fastapi-backend
DJANGO_IMAGE=multiframework-login-django-backend
NODE_IMAGE=multiframework-login-node-backend
DOTNET_IMAGE=multiframework-login-dotnet-backend
FRONTEND_IMAGE=multiframework-login-frontend
NGINX_IMAGE=multiframework-login-nginx
