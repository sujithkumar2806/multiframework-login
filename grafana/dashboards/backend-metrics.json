{
  "dashboard": {
    "title": "Multi-Framework Backend Metrics",
    "description": "Real-time metrics for all backends",
    "tags": ["fastapi", "django", "nodejs", "dotnet"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "FastAPI Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{framework=\"fastapi\"}[5m])",
            "legendFormat": "FastAPI",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Node.js Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{framework=\"node\"}[5m])",
            "legendFormat": "Node.js",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1
  }
}