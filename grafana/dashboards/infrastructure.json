{
  "dashboard": {
    "title": "Infrastructure Overview",
    "uid": "infrastructure-metrics",
    "description": "EC2 and Docker infrastructure metrics",
    "tags": ["infra", "docker"],
    "timezone": "browser",
    "schemaVersion": 27,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "Memory %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 3,
        "title": "System Load",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "node_load1",
            "legendFormat": "Load 1m",
            "refId": "A"
          },
          {
            "expr": "node_load5",
            "legendFormat": "Load 5m",
            "refId": "B"
          },
          {
            "expr": "node_load15",
            "legendFormat": "Load 15m",
            "refId": "C"
          }
        ]
      }
    ]
  }
}
