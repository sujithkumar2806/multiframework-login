{
  "dashboard": {
    "title": "EC2 Server Monitor",
    "uid": "ec2-monitor",
    "timezone": "browser",
    "schemaVersion": 27,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage %",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 90}
          ]}
        }}
      },
      {
        "id": 2,
        "title": "RAM Usage %",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %",
          "refId": "A"
        }],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 90}
          ]}
        }}
      },
      {
        "id": 3,
        "title": "Disk Usage % (Root /)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [{
          "expr": "((node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_avail_bytes{mountpoint=\"/\"}) / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %",
          "refId": "A"
        }],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 85}
          ]}
        }}
      },
      {
        "id": 4,
        "title": "Network Traffic (bytes/sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{device=\"ens5\"}[5m])",
            "legendFormat": "Receive",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{device=\"ens5\"}[5m])",
            "legendFormat": "Transmit",
            "refId": "B"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "Bps"}}
      },
      {
        "id": 5,
        "title": "System Load (1m / 5m / 15m)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {"expr": "node_load1", "legendFormat": "1 min", "refId": "A"},
          {"expr": "node_load5", "legendFormat": "5 min", "refId": "B"},
          {"expr": "node_load15", "legendFormat": "15 min", "refId": "C"}
        ],
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 6,
        "title": "Disk Free Space",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [{
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}",
          "legendFormat": "Free Space",
          "refId": "A"
        }],
        "fieldConfig": {"defaults": {"unit": "bytes"}}
      }
    ]
  },
  "overwrite": true
}
